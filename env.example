# FPL AI Pro Environment Configuration

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_51234567890abcdef...
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef...
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef...

# Redis Cache Configuration (for South African optimization)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Database Configuration (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/fplai

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Email Configuration (for subscriptions)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Deployment Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# South African Specific
TIMEZONE=Africa/Johannesburg
CURRENCY=ZAR

# External APIs
FPL_API_BASE=https://fantasy.premierleague.com/api
NEWS_API_KEY=your-news-api-key-for-sentiment-analysis

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-for-error-tracking