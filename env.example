# FPL AI Pro Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
API_BASE_URL=http://localhost:8000

# Database Configuration
DATABASE_URL=sqlite:///./local_fpl.db
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# External API Keys
NEWS_API_KEY=your_news_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
SPORTMONKS_API_KEY=your_sportmonks_api_key_here
FPL_API_BASE=https://fantasy.premierleague.com/api

# Payment Integration (PayStack for South Africa - preferred over Stripe)
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Legacy Stripe (deprecated in favor of PayStack)
STRIPE_SECRET_KEY=sk_test_51234567890abcdef...
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef...
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef...

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
API_SECRET_KEY=your_api_secret_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Email Configuration (for subscriptions)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Environment Settings
NODE_ENV=development
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# South African Specific
TIMEZONE=Africa/Johannesburg
CURRENCY=ZAR

# Model Configuration
MODEL_CACHE_TTL=300
ENABLE_AI_MODELS=true
USE_GEMINI_AI=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-for-error-tracking