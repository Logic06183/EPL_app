{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "app/**",
      "components/**",
      "lib/**",
      "src/**",
      "out/**",
      "public/**",
      "**/*.md",
      "package.json",
      "package-lock.json",
      "next.config.js",
      "postcss.config.js",
      "tailwind.config.js",
      "Dockerfile",
      "Dockerfile.dev",
      "nginx.conf"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  }
}
